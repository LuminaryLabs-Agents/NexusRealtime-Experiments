{
  "appId": "endless-vr-platformer-board-openxr",
  "version": "0.5.0",
  "runtime": "native-openxr",
  "contract": "endless-vr-platformer-board.manifest.v1",
  "sourcePackage": "@luminarylabs/nexusrealtime-protokits/vr-platformer-kit-suite",
  "bridge": {
    "status": "native-host-renders-endless-eye-level-platformer-board",
    "rule": "Native OpenXR host owns headset session, stereo images, trigger input, click burst input, and drawing; ProtoKit domains define the endless platformer and spatial board contract.",
    "requiredKits": [
      "platformer-avatar-domain-kit",
      "platformer-physics-system-kit",
      "platformer-render-descriptor-kit",
      "platformer-effects-domain-kit",
      "xr-pose-domain-kit",
      "xr-input-adapter-kit",
      "spatial-game-board-domain-kit",
      "stereoscopic-render-domain-kit",
      "xr-platformer-render-adapter-kit"
    ]
  },
  "controls": {
    "trigger": "jump only",
    "click": "burst particle effect on the 2D board"
  },
  "board": {
    "id": "endless-platformer-board",
    "mode": "endless-auto-runner",
    "positionMeters": [0.0, 1.55, -2.0],
    "height": "eye-level"
  }
}
