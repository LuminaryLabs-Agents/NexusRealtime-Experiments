{
  "version": 1,
  "sourceReplayManifest": "experiments/canonical-route-replay-manifest.json",
  "policy": "Compact lane replay contracts define the fixed-tick shape each canonical route lane must eventually execute. They are renderer-free bridge contracts, not reusable kit implementation.",
  "requiredSurfaces": [
    "resources",
    "events",
    "methods",
    "snapshots",
    "descriptors"
  ],
  "browserOwnershipExcluded": [
    "DOM",
    "Canvas",
    "WebGL",
    "Three.js",
    "pointer lock",
    "browser audio",
    "asset loading"
  ],
  "contracts": [
    {
      "id": "traversal-cargo-pressure",
      "higherLevelDomain": "Delivery/extraction loop",
      "canonicalIds": ["next-ledge"],
      "contractType": "planned-fixture-contract",
      "executionStatus": "contract-only",
      "fixedTickPlan": { "count": 180, "dt": 0.016667, "totalSeconds": 3 },
      "setup": {
        "minimalConfig": "route checkpoints, one cargo or tether target, one stamina/pressure meter, and descriptor ids for route ledger, carried state, and destination",
        "entities": ["actor", "checkpoint-a", "cargo-a", "dropoff-a"]
      },
      "inputs": [
        { "frame": 0, "method": "route.enterCheckpoint", "args": ["checkpoint-a"] },
        { "frame": 15, "method": "cargo.pickup", "args": ["cargo-a"] },
        { "frame": 90, "method": "route.enterCheckpoint", "args": ["dropoff-a"] },
        { "frame": 120, "method": "cargo.deliver", "args": ["cargo-a", "dropoff-a"] }
      ],
      "assertions": {
        "resources": ["routeLedger", "cargoState", "pressureMeter"],
        "events": ["CheckpointEntered", "CargoPickedUp", "CargoDelivered", "RouteCompleted"],
        "methods": ["enterCheckpoint", "pickup", "deliver", "getSnapshot"],
        "snapshots": ["route.complete", "cargo.carried", "pressure.value"],
        "descriptors": ["checkpoint", "cargo", "dropoff", "route-hud"]
      },
      "determinism": {
        "digestFields": ["routeLedger", "cargoState", "events", "descriptors"],
        "nondeterminismRisk": "host movement and presentation must be bridged into semantic methods before replay"
      },
      "localJsReductionSignal": [
        "checkpoint ledger and cargo/tether ownership should move behind reusable DSK resources",
        "route host should render descriptor snapshots only"
      ],
      "missingExecutableFixture": "checkpoint/cargo/tether deterministic replay lane"
    },
    {
